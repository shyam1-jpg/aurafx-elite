# Copy to Render Environment (or local set commands). Do not commit real secrets.

# Neon Postgres — persistent registrations (see NEON-SETUP.txt)
DATABASE_URL=

SITE_URL=https://aurafxelite.com
PORT=3847
HOST=0.0.0.0

# Owner tools — change from default
AURAFX_OWNER_KEY=change_me_to_a_long_secret

# PayPal — Client ID is public in browser; Secret is SERVER ONLY
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_BUSINESS_EMAIL=your-paypal@email.com
# Local testing only (0 in production)
ALLOW_MANUAL_PAYMENT_CONFIRM=0

# Optional AES-256 encryption for phone/address at rest (64 hex chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DATA_ENCRYPTION_KEY=

# Email (Resend) — https://resend.com
RESEND_API_KEY=
EMAIL_FROM=AuraFX Elite <hello@aurafxelite.com>
EMAIL_REPLY_TO=support@aurafxelite.com
EMAIL_AUTO_WELCOME=0
# Verification email sends on every registration when RESEND_API_KEY is set

# Optional AI email drafts
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Institutional live preview (owner only until public)
INSTITUTIONAL_MODE=demo
